  "author": "Nace Logar (https://github.com/TheCodeDestroyer)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheCodeDestroyer/codesight-plugin-convex.git"
  },
  "bugs": {
    "url": "https://github.com/TheCodeDestroyer/codesight-plugin-convex/issues"
  },
  "homepage": "https://github.com/TheCodeDestroyer/codesight-plugin-convex#readme",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "codesight": ">=1.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.2",
    "codesight": "^1.9.1",
    "typescript": "^5.7.0"
  }
