{
  "name": "codesight-plugin-convex",
  "version": "0.1.1",
  "description": "Codesight plugin for Convex backend — detects routes, schemas, and actions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome check --fix .",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "codesight",
    "codesight-plugin",
    "convex",
    "convex-backend",
    "route-detection",
    "schema-extraction"
